# Google OAuth client IDs — get these from Google Cloud Console.
# See docs/ship-plan.md Phase 2B for step-by-step setup instructions.
#
# To use: copy this file to .env.local (which is gitignored) and paste the
# real client ID strings from console.cloud.google.com → Credentials.

EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=
