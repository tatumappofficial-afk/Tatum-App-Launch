# Google OAuth client IDs — get these from Google Cloud Console.
# See docs/ship-plan.md Phase 2B for step-by-step setup instructions.
#
# To use: copy this file to .env.local (which is gitignored) and paste the
# real client ID strings from console.cloud.google.com → Credentials.
#
# OAuth client IDs are identifiers, not secrets. They are safe to expose in the
# app bundle as long as Google Cloud Console is configured for the correct app
# package/bundle IDs and signing fingerprints.

EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=

# Signup webhook. These are EXPO_PUBLIC because the mobile app calls the
# endpoint directly, which means they are embedded in the shipped JS bundle.
# EXPO_PUBLIC_SIGNUP_TOKEN is NOT a real secret; treat it only as a lightweight
# spam/abuse hint. The server must validate/rate-limit and must never allow this
# token to authorize reads, deletes, admin actions, or access to private data.
EXPO_PUBLIC_SIGNUP_WEBHOOK_URL=
EXPO_PUBLIC_SIGNUP_TOKEN=

# Dev-only: set to 1 to seed a heavy realistic dataset and skip onboarding on a
# fresh install (for iOS sim + Maestro testing). Double-gated — also requires a
# dev build (__DEV__). Leave unset for the normal onboarding flow. NEVER set
# this in the EAS production profile.
EXPO_PUBLIC_DEV_SEED=
