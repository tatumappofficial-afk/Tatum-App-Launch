{
  "cli": {
    "version": ">= 15.0.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "channel": "development"
    },
    "preview": {
      "distribution": "internal",
      "android": {
        "buildType": "apk"
      },
      "channel": "preview"
    },
    "production": {
      "autoIncrement": true,
      "environment": "production",
      "channel": "production"
    },
    "internalNoPaywall": {
      "autoIncrement": true,
      "environment": "production",
      "channel": "internal-free",
      "env": {
        "EXPO_PUBLIC_REVENUECAT_PAYWALL_ENABLED": "0",
        "EXPO_PUBLIC_REVENUECAT_PAYWALL_BYPASS": "1"
      }
    }
  },
  "submit": {
    "production": {
      "ios": {
        "ascAppId": "6773975406"
      }
    }
  }
}
