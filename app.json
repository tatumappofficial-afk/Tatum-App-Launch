{
  "expo": {
    "name": "Tatum",
    "slug": "tatum",
    "version": "1.0.0",
    "scheme": "tatum",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.tatumapp.tatum",
      "usesAppleSignIn": true,
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#502838"
      },
      "package": "com.tatumapp.tatum",
      "predictiveBackGestureEnabled": false,
      "allowBackup": true,
      "permissions": ["android.permission.USE_BIOMETRIC", "android.permission.USE_FINGERPRINT"]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-sqlite",
      "expo-font",
      "expo-image",
      [
        "expo-splash-screen",
        {
          "image": "./assets/splash-icon.png",
          "imageWidth": 260,
          "resizeMode": "contain",
          "backgroundColor": "#F5EFE8"
        }
      ],
      [
        "expo-local-authentication",
        {
          "faceIDPermission": "Tatum uses Face ID so only you can open your logs."
        }
      ],
      "./plugins/withAndroidWindowBackground",
      "expo-sharing",
      [
        "@react-native-google-signin/google-signin",
        {
          "iosUrlScheme": "com.googleusercontent.apps.242699264391-vf6a41rss675nk65pnglqo7vho6d4p5f"
        }
      ],
      [
        "expo-build-properties",
        {
          "ios": {
            "deploymentTarget": "16.4",
            "extraPods": [
              {
                "name": "GoogleUtilities",
                "modular_headers": true
              },
              {
                "name": "RecaptchaInterop",
                "modular_headers": true
              }
            ]
          }
        }
      ]
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "0f07d45e-b9fe-46f0-b58e-5f89f85f7b20"
      }
    },
    "owner": "tatum-app"
  }
}
