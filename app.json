{
  "expo": {
    "name": "tatum",
    "slug": "tatum",
    "version": "1.0.0",
    "scheme": "tatum",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#F5EFE8"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.skylightsocial.tatum"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#F5EFE8"
      },
      "package": "com.skylightsocial.tatum",
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-sqlite",
      "expo-font",
      "expo-image"
    ]
  }
}
